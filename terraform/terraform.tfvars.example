aws_region = "us-east-1"

instances = {
  "bot-alpha" = {
    telegram_bot_token = "123456:ABC-YOUR-TOKEN-HERE"
    telegram_dm_policy = "pairing"
  }
  "bot-beta" = {
    telegram_bot_token = "789012:DEF-YOUR-TOKEN-HERE"
    telegram_dm_policy = "allowlist"
    telegram_allow_from = ["12345678"]
  }
}

# API keys and secrets (passed as env vars to all instances)
secrets = {
  ANTHROPIC_API_KEY    = "sk-ant-..."
  OPENAI_API_KEY       = "sk-..."
  OPENAI_SKILL_API_KEY = "sk-..."
  BRAVE_API_KEY        = "..."
  GOOGLE_API_KEY       = "..."
  NOTION_API_KEY       = "ntn_..."
}

# Optional: clone a git repo as the agent workspace
# workspace_repo       = "https://github.com/your-org/your-workspace"
# workspace_repo_path  = "workspace"            # subdirectory within repo (optional)
# workspace_repo_token = "ghp_your-token-here"  # required for private repos

# Optional: SSH access
# ssh_public_key    = "ssh-ed25519 AAAA..."
# ssh_allowed_cidrs = ["1.2.3.4/32"]
