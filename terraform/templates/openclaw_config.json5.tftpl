{
  agents: {
    defaults: {
      model: {
        primary: "${model}"
      }
    }
  },
  channels: {
    telegram: {
      enabled: true,
      botToken: { source: "env", provider: "default", id: "TELEGRAM_BOT_TOKEN" },
      dmPolicy: "${telegram_dm_policy}",
%{ if length(telegram_allow_from) > 0 ~}
      allowFrom: ${jsonencode(telegram_allow_from)},
%{ endif ~}
    }
  },
  secrets: {
    providers: {
      default: { source: "env" }
    }
  },
  gateway: {
    port: 18789,
    bind: "lan"
  }
}
